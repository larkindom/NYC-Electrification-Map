# Mapbox public token (pk.*) — required to render the map
VITE_MAPBOX_TOKEN=

# NYC Open Data app token (data.cityofnewyork.us) — optional but recommended,
# raises the anonymous rate limit. Get one at https://data.cityofnewyork.us/profile/app_tokens
VITE_NYC_OPEN_DATA_APP_TOKEN=

# NY State Open Data app token (data.ny.gov) — optional, same purpose as
# above but for the DAC dataset, which is hosted on data.ny.gov not NYC's portal.
VITE_NYS_OPEN_DATA_APP_TOKEN=

# Anthropic API key — powers the sidebar's AI electrification audit.
# WARNING: this is a client-side app with no backend, so this key ships
# inside the built JS bundle and is readable by anyone who opens devtools on
# the deployed site. Fine for local use; do not deploy publicly without
# moving the call in src/lib/auditor.js behind a server-side proxy.
VITE_ANTHROPIC_API_KEY=
